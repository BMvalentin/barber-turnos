generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  relationMode = "prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

model account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model barbero {
  id          String                   @id @default(cuid())
  srcImage    String?
  nombre      String
  estado      Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  turnos      turno[]
  servicios   servicioxbarbero[]
  horarios    margen_laboral_barbero[]
  excepciones excepcion_laboral[]
}

model servicio {
  id          String             @id @default(cuid())
  descripcion String?
  nombre      String
  srcImage    String?
  estado      Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  descuento   Decimal            @default(0.00) @db.Decimal(10, 2)
  duracion    Int
  precio      Decimal            @db.Decimal(10, 2)
  senia       Decimal            @default(0.00) @db.Decimal(10, 2)
  turnos      turno[]
  servicios   servicioxbarbero[]
}

model Configuracion {
  id            String   @id @default("global")
  mpAccessToken String?  @db.Text
  mpPublicKey   String?  @db.Text
  updatedAt     DateTime @updatedAt

  @@map("configuraciones")
}

model turno {
  id               String       @id @default(cuid())
  userId           String
  barberoId        String
  servicioId       String
  horarioReservado DateTime
  precioCongelado  Decimal      @db.Decimal(10, 2)
  seniaCongelada   Decimal      @db.Decimal(10, 2)
  estado           turno_estado @default(PENDIENTE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  mpPaymentId      String?
  mpPreferenceId   String?
  user             user         @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbero          barbero      @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  servicio         servicio     @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([barberoId])
  @@index([servicioId])
}

model user {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          user_role @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  telefono      String?
  account       account[]
  turno         turno[]
}

model excepcion_laboral {
  id        String   @id @default(cuid())
  motivo    String
  desde     DateTime
  hasta     DateTime
  estado    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  barberoId String?
  barbero   barbero? @relation(fields: [barberoId], references: [id], onDelete: Cascade)

  @@index([barberoId])
}

model dia_laboral {
  id        String                   @id @default(cuid())
  estado    Boolean                  @default(true)
  dia       dias_laborales
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  margenes  margen_laboral[]
  horarios  margen_laboral_barbero[]
}

model margen_laboral {
  id           String                   @id @default(cuid())
  diaId        String
  desde        String
  hasta        String
  estado       Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  dia          dia_laboral              @relation(fields: [diaId], references: [id], onDelete: Cascade)
  asignaciones margen_laboral_barbero[]

  @@index([diaId])
}

model margen_laboral_barbero {
  id              String         @id @default(cuid())
  barberoId       String
  margenLaboralId String
  diaId           String
  estado          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  barbero         barbero        @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  margenLaboral   margen_laboral @relation(fields: [margenLaboralId], references: [id], onDelete: Cascade)
  dia             dia_laboral    @relation(fields: [diaId], references: [id], onDelete: Cascade)

  @@unique([barberoId, margenLaboralId, diaId])
  @@index([barberoId])
  @@index([margenLaboralId])
  @@index([diaId])
}

model servicioxbarbero {
  id         String   @id @default(cuid())
  barberoId  String
  servicioId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  barbero    barbero  @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  servicio   servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@unique([barberoId, servicioId], name: "barbero_servicio_unique")
  @@index([barberoId])
  @@index([servicioId])
}

model configuracion_mercadopago {
  id           String    @id
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  publicKey    String?
  mpUserId     String?
  scope        String?   @db.Text
  liveMode     Boolean   @default(true)
  conectado    Boolean   @default(true)
  expiraEn     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  bloqueado    Boolean   @default(true)
}

model SlotLock {
  id               String   @id @default(cuid())
  barberoId        String
  horarioReservado DateTime
  userId           String
  sessionId        String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([barberoId, horarioReservado])
  @@index([expiresAt])
}


model PageConfig {
  id                   Int                       @id @default(1)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  //general
  name            String
  description          String?                   @db.Text
  slogan               String?
  logo                 String?                   @db.Text
  favicon              String?                   @db.Text
  primaryColor         String?                   @default("#000000")
  secondaryColor       String?                   @default("#FFFFFF")

  //Contacto
  phone                String?
  whatsapp             String?
  email                String?
  instagram            String?                   @db.Text

  //Location
  locationEnabled      Boolean                   @default(false)
  address              String?
  city                 String?
  province             String?
  country              String?
  postalCode           String?
  mapsUrl              String?                   @db.Text

  
  currency             String                    @default("ARS")
  language             String                    @default("es")
  maintenanceMode      Boolean                   @default(false)
  metaTitle            String?
  metaDescription      String?                   @db.Text
  termsAndConditions   String?                   @db.Text
  privacyPolicy        String?                   @db.Text
}

enum user_role {
  USER
  ADMIN
}

enum turno_estado {
  PENDIENTE
  CONFIRMADO
  CANCELADO
  COMPLETADO
}

enum dias_laborales {
  Lunes
  Martes
  Miercoles
  Jueves
  Viernes
  Sabado
  Domingo
}
