generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  relationMode = "prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

model account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              user    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model barbero {
  id                String             @id @default(cuid())
  margenLaboralId   String?
  srcImage          String?
  nombre            String
  estado            Boolean
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  margenes          margen_laboral[]
  servicios         servicio[]
  turnos            turno[]
}

model servicio {
  id                String              @id @default(cuid())
  barberoId         String
  descripcion       String?
  nombre            String?
  srcImage          String?
  estado            Boolean
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  barbero           barbero             @relation(fields: [barberoId], references: [id], onDelete: Cascade)
  turnoServicios    turno_servicio[]
  
  @@index([barberoId])
}

model turno {
  id                 String            @id @default(cuid())
  turnoXServicioId   String
  userId             String
  barberoId          String?
  horarioReservado   DateTime
  precioCongelado    Decimal           @db.Decimal(10, 2)
  seniaCongelada     Decimal           @db.Decimal(10, 2)
  estado             Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  user               user              @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbero            barbero?          @relation(fields: [barberoId], references: [id], onDelete: SetNull)
  turnoServicio      turno_servicio    @relation(fields: [turnoXServicioId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([turnoXServicioId])
  @@index([barberoId])
}

model user {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          user_role @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  telefono      String?
  account       account[]
  turno         turno[]
}

model turno_servicio {
  id         String   @id @default(cuid())
  servicioId String
  duracion   Int
  precio     Decimal  @db.Decimal(10, 2)
  descuento  Decimal  @db.Decimal(10, 2)
  senia      Decimal  @db.Decimal(10, 2)
  estado     Boolean
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  turnos     turno[]
  servicio   servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)

  @@index([servicioId])
}

model excepcion_laboral {
  id        String   @id @default(cuid())
  motivo    String
  desde     DateTime
  hasta     DateTime
  estado    Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model dia_laboral {
  id        String               @id @default(cuid())
  estado    Boolean
  dia       Int                  @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  margenes  margen_laboral[]
}

model margen_laboral {
  id        String      @id @default(cuid())
  diaId     String
  barberoId String
  estado    Boolean
  desde     String
  hasta     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  
  dia       dia_laboral @relation(fields: [diaId], references: [id], onDelete: Cascade)
  barbero   barbero     @relation(fields: [barberoId], references: [id], onDelete: Cascade)

  @@index([diaId])
  @@index([barberoId])
}


enum user_role {
  USER
  ADMIN
}